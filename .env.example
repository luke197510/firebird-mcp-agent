# Provider LLM attivo: "claude" oppure "mistral"
LLM_PROVIDER=claude

# Chiavi API — NON committare mai i valori reali
ANTHROPIC_API_KEY=your-anthropic-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here

# Firebird 2.5
# IMPORTANTE: usare un utente con permessi di SOLA LETTURA sul database.
# Il filtro applicativo sulle SELECT è un controllo sintattico, non una
# garanzia di sicurezza: la vera protezione sono i permessi del DB.
FIREBIRD_HOST=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=/path/to/database.fdb
FIREBIRD_USER=readonly_user
FIREBIRD_PASSWORD=your-password-here
